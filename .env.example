APP_NAME="Tulutala CMS"
APP_ENV=local
APP_DEBUG=true
APP_URL=https://tulutala-local.test
APP_DOMAIN=tulutala-local.test
APP_KEY=
APP_LOCALE=en
APP_VERSION=1.0.0
APP_CONTACT_EMAIL=
APP_TEMP_PATH=
ASSET_URL=

# Sử dụng detect cho phù hợp multisite
LINK_POLICY="detect"

LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_DEPRECATIONS_CHANNEL=null
LOG_STDERR_FORMATTER=
LOG_SLACK_WEBHOOK_URL=
LOG_PAPERTRAIL_HANDLER=
PAPERTRAIL_URL=
PAPERTRAIL_PORT=

ENABLE_CSRF=true
ROUTES_CACHE=false
ASSET_CACHE=false
DATABASE_TEMPLATES=false
RESTRICT_BASE_DIR=true
DEBUG_SNOWBOARD=false
VIEW_COMPILED_PATH=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=winter
DB_USERNAME=winter
DB_PASSWORD=winter
DB_SOCKET=
DATABASE_URL=
DB_FOREIGN_KEYS=true
MYSQL_ATTR_SSL_CA=

CACHE_DRIVER=file
CACHE_PREFIX=
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_CONNECTION=
SESSION_STORE=
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
QUEUE_CONNECTION=sync
QUEUE_FAILED_DRIVER=database-uuids
