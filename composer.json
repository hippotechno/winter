    "scripts": {
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [

        ],
        "post-update-cmd": [
            "php artisan winter:version",
            "php artisan package:discover"
        ],
        "test": [
            "phpunit --stop-on-failure"
        ],
        "lint": [
            "parallel-lint --exclude vendor --exclude storage --exclude modules/system/tests/fixtures/plugins/testvendor/goto/Plugin.php ."
        ],
        "sniff": [
            "phpcs --colors -nq --report=\"full\" --extensions=\"php\""
        ],
        "hippo-runner": [
            "php plugins/hippo/core/scripts/hippo-runner.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "installer-paths": {
            "themes/wn-bg360-theme/": [
                "hippo/wn-bg360-theme"
            ],
            "themes/wn-decorgreen-theme/": [
                "hippo/wn-decorgreen-theme"
            ],
            "themes/wn-gaion-theme/": [
                "hippo/wn-gaion-theme"
            ],
            "themes/wn-researchvn-theme/": [
                "hippo/wn-researchvn-theme"
            ],
            "themes/wn-thomo-theme/": [
                "hippo/wn-thomo-theme"
            ],
            "themes/wn-thungiay-theme/": [
                "hippo/wn-thungiay-theme"
            ],
            "themes/wn-tombo-theme/": [
                "hippo/wn-tombo-theme"
            ]
        },
        "merge-plugin": {
            "include": [
                "plugins/hippo/*/composer.json"
            ],
            "recurse": true,
            "replace": false,
            "merge-replace": false,
            "merge-dev": false
        }
    },
    "config": {
        "preferred-install": {
            "hippo/*": "source",
            "*": "dist"
        },
        "allow-plugins": {
            "composer/installers": true,
            "wikimedia/composer-merge-plugin": true,
            "php-http/discovery": true
        }
    }
}
