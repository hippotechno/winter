{
    "name": "hippo/winter",
    "description": "Rebuild, self-hosted CMS platform based on the Laravel PHP Framework. Originally known as Winter CMS AKA October CMS.",
    "homepage": "https://tulutala.com",
    "type": "project",
    "keywords": [
        "winter",
        "cms",
        "wintercms",
        "laravel",
        "cmf",
        "hippo",
        "hippotechno"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Alexey Bobkov",
            "email": "aleksey.bobkov@gmail.com",
            "role": "Original Author"
        },
        {
            "name": "Samuel Georges",
            "email": "daftspunky@gmail.com",
            "role": "Original Author"
        },
        {
            "name": "Luke Towers",
            "email": "wintercms@luketowers.ca",
            "role": "Lead Maintainer"
        }
    ],
    "support": {
        "source": "https://github.com/hippotechno/winter"
    },
    "require": {
        "laravel/framework": "^9.52",
        "php": "^8.0.2",
        "php-http/guzzle7-adapter": "^1.1",
        "tpetry/laravel-postgresql-enhanced": "*",
        "wikimedia/composer-merge-plugin": "~2.1.0",
        "winter/storm": "1.2.12",
        "winter/wn-backend-module": "1.2.12",
        "winter/wn-cms-module": "1.2.12",
        "winter/wn-system-module": "1.2.12",
        "winter/wn-translate-plugin": "2.3.2",
        "winter/wn-location-plugin": "2.2.0",
        "winter/wn-blocks-plugin": "dev-main",
        "barryvdh/laravel-dompdf": "^3.1",
        "composer/installers": "^1.11 || ^2.0",
        "google/protobuf": "^4.33",
        "grpc/grpc": "^1.74"
    },
    "require-dev": {
        "dms/phpunit-arraysubset-asserts": "^0.1.0|^0.2.1",
        "fakerphp/faker": "^1.9.2",
        "mockery/mockery": "^1.4.4",
        "php-parallel-lint/php-parallel-lint": "^1.0",
        "phpunit/phpunit": "^9.5.8",
        "squizlabs/php_codesniffer": "^3.2"
    },
    "scripts": {
        "post-create-project-cmd": [
            "php artisan key:generate"
        ],
        "post-install-cmd": [],
        "post-update-cmd": [
            "php artisan winter:version",
            "php artisan package:discover"
        ],
        "test": [
            "phpunit --stop-on-failure"
        ],
        "lint": [
            "parallel-lint --exclude vendor --exclude storage --exclude modules/system/tests/fixtures/plugins/testvendor/goto/Plugin.php ."
        ],
        "sniff": [
            "phpcs --colors -nq --report=\"full\" --extensions=\"php\""
        ],
        "hippo-runner": [
            "php plugins/hippo/core/scripts/hippo-runner.php"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "merge-plugin": {
            "include": [
                "plugins/hippo/*/composer.json"
            ],
            "recurse": true,
            "replace": false,
            "merge-replace": false,
            "merge-dev": false
        }
    },
    "config": {
        "preferred-install": {
            "*": "dist"
        },
        "audit": {
            "abandoned": "report",
            "ignore": {
                "GHSA-78fx-h6xr-vch4": "Blocked by the WinterCMS 1.2 / Laravel 9 stack. The patched Laravel versions start at 10.48.29; handle in the planned framework upgrade.",
                "GHSA-2x45-7fc3-mxwq": "Blocked by laravel/passport 10.x and google/auth 1.x constraints on firebase/php-jwt ^6. Handle when upgrading the OAuth/auth dependency stack to php-jwt 7."
            }
        },
        "allow-plugins": {
            "composer/installers": true,
            "wikimedia/composer-merge-plugin": true,
            "php-http/discovery": true
        }
    }
}
