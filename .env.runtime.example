APP_IMAGE=ghcr.io/your-org/winter-app:latest
APP_CONTAINER_NAME=winter-app
APP_PORT=8080

APP_NAME="Winter CMS"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_KEY=
APP_LOCALE=vi

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=winter
DB_USERNAME=winter
DB_PASSWORD=change_me

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

RUN_MIGRATIONS=false
